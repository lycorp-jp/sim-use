{
  "name": "sim-use-viewer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Web-based viewer for sim-use describe-ui output.",
  "scripts": {
    "dev": "concurrently -k -n viewer,web -c cyan,magenta \"${SIM_USE_BIN:-sim-use} viewer --no-open --port 4000\" \"vite\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "typescript": "^5.5.3",
    "vite": "^5.3.3"
  }
}
