# Xcode
*.xcodeproj
*.xcworkspace
!*.xcworkspace/contents.xcworkspacedata
!*.xcworkspace/xcshareddata/
!*.xcworkspace/xcshareddata/xcschemes/
*.xcuserdatad

# Swift Package Manager
.build/
.swiftpm/

# Transient build artifacts and dependencies
idb_checkout/
/build_products
/build_derived_data
/dist

# TypeScript incremental build cache
*.tsbuildinfo

# Generated version file
Sources/SimUse/Version.swift

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Thumbnails
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP share
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# VSCode
.vscode
/.cursorrules

# Other
/keys
/buildServer.json

# Android bridge build artifacts. `bridge/` is a separate Gradle
# project; everything under build/, .gradle/ and local.properties is
# per-machine / regenerated by `scripts/build-bridge.sh`.
bridge/.gradle/
bridge/build/
bridge/app/build/
bridge/local.properties
bridge/.idea/
bridge/*.iml
bridge/app/*.iml
bridge/captures/

# The bridge APK is a build output, not a source artifact. The Swift
# `AndroidBackend` target loads it from `Sources/AndroidBackend/Resources/`
# at runtime; populate that path locally via `scripts/build-bridge.sh`.
# `swift build` succeeds without it; `sim-use android init` then prints
# a clear "build the bridge first" error.
Sources/AndroidBackend/Resources/*.apk

# The Viewer SPA is a build output, not a source artifact. Source lives
# in Tools/Viewer/; regenerate the bundled tree via `make viewer` (or
# `scripts/build-viewer.sh`). `swift build` succeeds without the dist;
# `sim-use viewer` then prints a clear "build the Viewer first" error.
# `.gitkeep` is tracked so SwiftPM `.copy("Resources/viewer")` always
# has a directory to copy.
# Bundled skill (source of truth: skills/sim-use/; synced by `make build`)
Sources/SimUse/Resources/skills/sim-use/

Sources/SimUse/Resources/viewer/*
!Sources/SimUse/Resources/viewer/.gitkeep
*.profraw
