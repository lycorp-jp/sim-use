diff --git a/FBSimulatorControl/HID/FBSimulatorIndigoHID.h b/FBSimulatorControl/HID/FBSimulatorIndigoHID.h
index 53902903..c9c9b0a4 100644
--- a/FBSimulatorControl/HID/FBSimulatorIndigoHID.h
+++ b/FBSimulatorControl/HID/FBSimulatorIndigoHID.h
@@ -83,6 +83,46 @@ typedef NS_ENUM(int, FBSimulatorHIDButton) {
  */
 - (NSData *)touchScreenSize:(CGSize)screenSize screenScale:(float)screenScale direction:(FBSimulatorHIDDirection)direction x:(double)x y:(double)y;
 
+/**
+ Multi-touch gesture phase. Maps to NSEventType + digitizer-stream
+ direction internally — see `multiTouchScreenSize:...:phase:...` for
+ the encoding.
+ */
+typedef NS_ENUM(int, FBSimulatorMultiTouchPhase) {
+  FBSimulatorMultiTouchPhaseDown = 0,
+  FBSimulatorMultiTouchPhaseMove = 1,
+  FBSimulatorMultiTouchPhaseUp   = 2,
+};
+
+/**
+ A Multi-Touch Event with two simultaneous contact points.
+
+ Builds an `IndigoMessage` via the 9-argument shape of
+ `IndigoHIDMessageForMouseNSEvent` — `(point0, point1, target,
+ eventType, direction, 1.0, 1.0, widthPoints, heightPoints)` — so
+ SimulatorKit produces the entire two-payload packet with all the
+ IndigoTouch state bits set correctly in both slots. The 5-arg
+ shape that the single-touch path uses cannot do this; it leaves
+ the second slot uninitialised in a way iOS treats as a phantom
+ touch.
+
+ The 5-arg and 9-arg shapes are the SAME symbol in SimulatorKit;
+ the function reads x4..x7 + d0..d3 unconditionally on ARM64. The
+ 5-arg shape works for single-touch only because the function's
+ internal NULL-point1 branch short-circuits before reading those
+ slots.
+
+ @param screenSize the size of the screen in pixels.
+ @param screenScale the scale of the screen e.g. @2x
+ @param phase Down (touch-began), Move (touch-moved while held), or Up (touch-ended).
+ @param x1 first finger X in pixels (in screen coordinate space)
+ @param y1 first finger Y in pixels
+ @param x2 second finger X in pixels
+ @param y2 second finger Y in pixels
+ @return an NSData-Wrapped IndigoMessage, or nil if the symbol returned nil.
+ */
+- (NSData *)multiTouchScreenSize:(CGSize)screenSize screenScale:(float)screenScale phase:(FBSimulatorMultiTouchPhase)phase x1:(double)x1 y1:(double)y1 x2:(double)x2 y2:(double)y2;
+
 @end
 
 NS_ASSUME_NONNULL_END
diff --git a/FBSimulatorControl/HID/FBSimulatorIndigoHID.m b/FBSimulatorControl/HID/FBSimulatorIndigoHID.m
index b7b30fe1..4be99131 100644
--- a/FBSimulatorControl/HID/FBSimulatorIndigoHID.m
+++ b/FBSimulatorControl/HID/FBSimulatorIndigoHID.m
@@ -22,6 +22,26 @@
   IndigoMessage *(*MessageForButton)(int keyCode, int op, int target);
   IndigoMessage *(*MessageForKeyboardArbitrary)(int keyCode, int op);
   IndigoMessage *(*MessageForMouseNSEvent)(CGPoint *point0, CGPoint *point1, int target, int eventType, BOOL something);
+  /*
+   * Xcode 26 SimulatorKit exposes a 9-argument shape of
+   * `IndigoHIDMessageForMouseNSEvent` that natively supports
+   * two-finger touches: pass non-NULL `point1` (the second finger)
+   * plus eventType / direction codes split into two separate ints,
+   * two `1.0` doubles, and the screen size in points. Verified via
+   * the tddworks/baguette project (Apache 2.0). The 5-arg shape
+   * above and this one are the SAME symbol in SimulatorKit — the
+   * function reads x4..x7 + d0..d3 unconditionally on ARM64; calling
+   * it with 5 args while the second pointer is NULL works because
+   * the function's NULL-p1 branch never reads those slots. For
+   * two-finger packets we must use this full signature so all the
+   * IndigoTouch state bits land correctly in BOTH slots, not just
+   * slot 1.
+   */
+  IndigoMessage *(*MessageForMouseNSEventMultiTouch)(
+    CGPoint *point0, CGPoint *point1,
+    uint32_t target, uint32_t eventType, uint32_t direction,
+    double unused1, double unused2,
+    double widthPoints, double heightPoints);
 } IndigoCalls;
 
 @interface FBSimulatorIndigoHID ()
@@ -42,10 +62,14 @@ + (instancetype)simulatorKitHIDWithError:(NSError **)error
     return nil;
   }
   void *handle = [[NSBundle bundleWithIdentifier:@"com.apple.SimulatorKit"] dlopenExecutablePath];
+  void *mouseSymbol = FBGetSymbolFromHandle(handle, "IndigoHIDMessageForMouseNSEvent");
   const IndigoCalls calls = {
     .MessageForButton = FBGetSymbolFromHandle(handle, "IndigoHIDMessageForButton"),
     .MessageForKeyboardArbitrary = FBGetSymbolFromHandle(handle, "IndigoHIDMessageForKeyboardArbitrary"),
-    .MessageForMouseNSEvent = FBGetSymbolFromHandle(handle, "IndigoHIDMessageForMouseNSEvent"),
+    // Same symbol, two typedefs — the 5-arg shape for single-touch
+    // (back-compat) and the 9-arg shape for multi-touch.
+    .MessageForMouseNSEvent = mouseSymbol,
+    .MessageForMouseNSEventMultiTouch = mouseSymbol,
   };
   return [[self alloc] initWithCalls:calls];
 }
@@ -92,6 +116,56 @@ - (NSData *)touchScreenSize:(CGSize)screenSize screenScale:(float)screenScale di
   return [NSData dataWithBytesNoCopy:message length:messageSize freeWhenDone:YES];
 }
 
+- (NSData *)multiTouchScreenSize:(CGSize)screenSize screenScale:(float)screenScale phase:(FBSimulatorMultiTouchPhase)phase x1:(double)x1 y1:(double)y1 x2:(double)x2 y2:(double)y2
+{
+  // 9-arg `IndigoHIDMessageForMouseNSEvent` takes NORMALIZED 0..1
+  // coordinates AND the screen size in points; the latter lets the
+  // gesture recogniser scale the internal IOHIDEvent properly. We
+  // pass scaled (point.x * scale / sizeInPixels), matching the
+  // single-touch path's `screenRatioFromPoint:`.
+  CGPoint p1 = [self.class screenRatioFromPoint:CGPointMake(x1, y1) screenSize:screenSize screenScale:screenScale];
+  CGPoint p2 = [self.class screenRatioFromPoint:CGPointMake(x2, y2) screenSize:screenSize screenScale:screenScale];
+
+  // Map our phase enum to the (eventType, direction) pair the
+  // SimulatorKit builder expects. eventType mirrors NSEventType:
+  //   1 = NSEventTypeLeftMouseDown
+  //   6 = NSEventTypeLeftMouseDragged
+  //   2 = NSEventTypeLeftMouseUp
+  // direction is the digitizer-stream phase:
+  //   1 = down  /  0 = move  /  2 = up
+  uint32_t eventType, direction;
+  switch (phase) {
+    case FBSimulatorMultiTouchPhaseDown: eventType = 1; direction = 1; break;
+    case FBSimulatorMultiTouchPhaseMove: eventType = 6; direction = 0; break;
+    case FBSimulatorMultiTouchPhaseUp:   eventType = 2; direction = 2; break;
+    default: return nil;
+  }
+
+  // Screen size to pass to SimulatorKit. We pass *points*, not pixels.
+  // The single-touch path's `screenRatioFromPoint:` already includes
+  // the scale factor so the normalised coords are correct; here the
+  // size hint is just for the SimulatorKit-internal scaling logic.
+  double widthPoints = screenSize.width / screenScale;
+  double heightPoints = screenSize.height / screenScale;
+
+  IndigoMessage *message = self.calls.MessageForMouseNSEventMultiTouch(
+    &p1, &p2,
+    /* target = digitizer */ 0x32u,
+    eventType, direction,
+    1.0, 1.0,
+    widthPoints, heightPoints
+  );
+  if (!message) {
+    return nil;
+  }
+
+  // SimulatorKit owns the allocation. `malloc_size` reports the real
+  // block length so the NSData covers the full packet (header + both
+  // payload slots).
+  size_t messageSize = malloc_size(message);
+  return [NSData dataWithBytesNoCopy:message length:messageSize freeWhenDone:YES];
+}
+
