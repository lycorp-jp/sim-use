 - (FBFuture<NSNull *> *)sendTouchWithType:(FBSimulatorHIDDirection)type x:(double)x y:(double)y;
 
+/**
+ Sends a Multi-Touch Event with two simultaneous contact points.
+
+ Spike-only entry point for the sim-use multi-touch experiment.
+ Same mach-port transport as the single-touch path; the packet is
+ built by SimulatorKit via the 9-arg `IndigoHIDMessageForMouseNSEvent`
+ shape so both finger slots carry valid IndigoTouch state.
+
+ @param phase Down / Move / Up — Down begins both fingers, Move drives
+   the drag step (call repeatedly to interpolate), Up releases.
+ @param x1 first finger X in screen coordinates (pixels)
+ @param y1 first finger Y
+ @param x2 second finger X
+ @param y2 second finger Y
+ @return A future that resolves when the event has been sent.
+ */
+- (FBFuture<NSNull *> *)sendMultiTouchWithPhase:(FBSimulatorMultiTouchPhase)phase x1:(double)x1 y1:(double)y1 x2:(double)x2 y2:(double)y2;
+
 #pragma mark Properties
 
 /**
diff --git a/FBSimulatorControl/HID/FBSimulatorHID.m b/FBSimulatorControl/HID/FBSimulatorHID.m
index bc6f5d48..f7e83943 100644
--- a/FBSimulatorControl/HID/FBSimulatorHID.m
+++ b/FBSimulatorControl/HID/FBSimulatorHID.m
@@ -101,6 +101,15 @@ - (instancetype)initWithIndigo:(FBSimulatorIndigoHID *)indigo client:(SimDeviceL
   return [self sendIndigoMessageDataOnWorkQueue:[self.indigo touchScreenSize:self.mainScreenSize screenScale:self.mainScreenScale direction:type x:x y:y]];
 }
 
+- (FBFuture<NSNull *> *)sendMultiTouchWithPhase:(FBSimulatorMultiTouchPhase)phase x1:(double)x1 y1:(double)y1 x2:(double)x2 y2:(double)y2
+{
+  NSData *data = [self.indigo multiTouchScreenSize:self.mainScreenSize screenScale:self.mainScreenScale phase:phase x1:x1 y1:y1 x2:x2 y2:y2];
+  if (!data) {
+    return [[FBSimulatorError describe:@"MessageForMouseNSEvent returned nil for multi-touch event"] failFuture];
+  }
+  return [self sendIndigoMessageDataOnWorkQueue:data];
+}
+
