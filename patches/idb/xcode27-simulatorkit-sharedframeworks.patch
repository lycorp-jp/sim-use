diff --git a/FBControlCore/Utility/FBWeakFramework+ApplePrivateFrameworks.m b/FBControlCore/Utility/FBWeakFramework+ApplePrivateFrameworks.m
index 0d09ee653..83133d701 100644
--- a/FBControlCore/Utility/FBWeakFramework+ApplePrivateFrameworks.m
+++ b/FBControlCore/Utility/FBWeakFramework+ApplePrivateFrameworks.m
@@ -22,6 +22,15 @@ + (instancetype)CoreSimulator
 
 + (instancetype)SimulatorKit
 {
+  // Xcode 27 moved SimulatorKit.framework from Contents/Developer/Library/PrivateFrameworks
+  // to Contents/SharedFrameworks. Prefer the new location, falling back to the legacy one for
+  // Xcode <= 26. (Backport of upstream idb commit 98110129.)
+  NSString *sharedPath = [[FBXcodeConfiguration.developerDirectory
+    stringByAppendingPathComponent:@"../SharedFrameworks/SimulatorKit.framework"]
+    stringByStandardizingPath];
+  if ([NSFileManager.defaultManager fileExistsAtPath:sharedPath]) {
+    return [FBWeakFramework frameworkWithPath:sharedPath requiredClassNames:@[] rootPermitted:NO];
+  }
   return [FBWeakFramework xcodeFrameworkWithRelativePath:@"Library/PrivateFrameworks/SimulatorKit.framework" requiredClassNames:@[]];
 }
 
